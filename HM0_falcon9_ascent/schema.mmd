    classDef decision  fill:#8b4513,color:#fff,stroke:#5c2d0a
    classDef process   fill:#1a3d6b,color:#fff,stroke:#0d2040
    classDef subprocess fill:#4a235a,color:#fff,stroke:#2d1438
    classDef io        fill:#1a5c4a,color:#fff,stroke:#0d3d30
    classDef event_fn  fill:#6b4f00,color:#fff,stroke:#3d2d00

    class START,STOP startstop
    class ARC_DEC,ARC12,DRAG_DEC,PHASE_DEC,PH3_DEC,LOOP_VREL,GT_DEC1,GT_DEC2,LOOP_NEXT,MACH_CHECK,EV2 decision
    class PARAMS,SITE,REFSCALES,NDPARAMS,IC,ARCS,PAR,OPTS process
    class TNS,UNPACK,ATM,VREL_CALC,GRAV,DRAG,NODRAG,THRUST_MAG,PH1,PH2,PH3,PH3B,KIN,DYN,DMASS,SCALE subprocess
    class TRECOV,CONVBACK,DERIVED,MISSION_EV,ENU,CONSOLE,PRINT_M1,FIGS,FIG9,GT1,GT2,GT3,GA_90,CALC_GA io
    class ODE,LOOP_START,LOOP_NEXT event_fn
