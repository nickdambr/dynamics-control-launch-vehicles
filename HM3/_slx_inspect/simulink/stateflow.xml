            <eml>
              <P Name="isEML">1</P>
              <P Name="script">function [v_wp,c] = fcn(h,A,Hl,Hu,Hf)
    if h &lt; Hl
        v_wp = 10*A*(((h/2000)^(0.9))-0.9*(h/Hl));
        c = 1;
    elseif h &gt;= Hl &amp; h &lt;= Hf-Hu
        v_wp = A;
        c = 2;
    elseif h &gt; Hf-Hu &amp; h &lt;=Hf
        v_wp = A/2*(1 - cos((pi/Hu)*(h-Hf)));
        c = 3;
    else 
        v_wp = 0;
        c = 4;
    end
</P>
              <P Name="editorLayout" Class="double">Matrix(4,1)
[10.0, 5.0, 700.0, 500.0]</P>
